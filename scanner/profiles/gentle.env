# COMMANDsentry — rate limit profile: GENTLE
# For WAF-twitchy targets (FortiWeb, Pressable shared, anything that bans on volume).

SUBFINDER_CONCURRENCY=5
DNSX_THREADS=10
HTTPX_THREADS=10
NAABU_RATE=300
NUCLEI_CONCURRENCY=10
NUCLEI_RATE_LIMIT=50

HTTP_DELAY_MS=500

PHASE_TIMEOUT=900        # 15 min — gentle = slower
TOTAL_TIMEOUT=2700       # 45 min total

NAABU_TOP_PORTS=100      # only top 100 TCP — less noise

NUCLEI_TAGS="exposure,disclosure"
NUCLEI_EXCLUDE_TAGS="cve,intrusive,fuzz,misconfig"
NUCLEI_SEVERITY="info,low"
