# COMMANDsentry — rate limit profile: AGGRESSIVE
# For lab / dev / authorized internal targets only.
# Will probably get blocked by any real WAF. Don't use against prod.

SUBFINDER_CONCURRENCY=20
DNSX_THREADS=50
HTTPX_THREADS=50
NAABU_RATE=2500
NUCLEI_CONCURRENCY=50
NUCLEI_RATE_LIMIT=300

HTTP_DELAY_MS=0

PHASE_TIMEOUT=300
TOTAL_TIMEOUT=900

NAABU_TOP_PORTS=1000

NUCLEI_TAGS="exposure,misconfig,disclosure"
NUCLEI_EXCLUDE_TAGS="cve,intrusive,fuzz"
NUCLEI_SEVERITY="info,low,medium"
