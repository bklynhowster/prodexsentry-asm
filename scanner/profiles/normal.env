# COMMANDsentry — rate limit profile: NORMAL (default)
# Reasonable speed, won't trip most WAFs.

# Concurrency caps
SUBFINDER_CONCURRENCY=10
DNSX_THREADS=25
HTTPX_THREADS=25
NAABU_RATE=1000          # packets per second
NUCLEI_CONCURRENCY=25
NUCLEI_RATE_LIMIT=150    # requests per second

# Per-request delays (ms)
HTTP_DELAY_MS=100

# Timeouts (seconds)
PHASE_TIMEOUT=600        # 10 min per phase
TOTAL_TIMEOUT=1800       # 30 min total per asset

# Port scope
NAABU_TOP_PORTS=1000     # top 1000 TCP

# Nuclei filter
NUCLEI_TAGS="exposure,misconfig,disclosure"
NUCLEI_EXCLUDE_TAGS="cve,intrusive,fuzz"
NUCLEI_SEVERITY="info,low,medium"
