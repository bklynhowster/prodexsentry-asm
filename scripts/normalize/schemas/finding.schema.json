{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commandsentry/schemas/finding.schema.json",
  "title": "Finding",
  "description": "A vulnerability or issue with stable identity across scans. The same finding observed in 5 scans = ONE finding record with 5 history entries.",
  "type": "object",
  "required": ["finding_id", "asset_id", "title", "severity", "category", "current_status", "first_detected_at"],
  "properties": {
    "finding_id":          { "type": "string", "description": "Stable identity. Format: <asset>:<short>. Named findings use the assigned short (H-01, C-01, M-03). Tool-generated findings use <tool>:<template_id>:<hash>." },
    "asset_id":            { "type": "string" },
    "title":               { "type": "string" },
    "severity":            { "type": "string", "enum": ["CRITICAL", "HIGH", "MODERATE-HIGH", "MODERATE", "LOW", "INFO"] },
    "category":            {
      "type": "string",
      "enum": ["sast", "dast", "sca", "secret", "recon", "tls", "headers", "dns", "email", "auth", "session", "csrf", "ssrf", "xxe", "xss", "sqli", "idor", "rce", "lfi", "redirect", "info_disclosure", "takeover", "typosquat", "config", "deprecation", "supply_chain", "other"]
    },
    "description":         { "type": "string" },
    "cwe":                 { "type": "array", "items": { "type": "integer" } },
    "cve":                 { "type": "array", "items": { "type": "string" } },
    "references":          { "type": "array", "items": { "type": "string" }, "description": "External or internal links: Sprocket finding URL, vendor advisory, Obsidian note path with internal:// scheme." },
    "current_status":      { "type": "string", "enum": ["detected", "confirmed", "open", "remediated", "validated_remediated", "regressed", "false_positive", "wont_fix", "accepted_risk"] },
    "first_detected_at":   { "type": "string", "format": "date-time" },
    "first_detected_scan": { "type": "string" },
    "last_observed_at":    { "type": "string", "format": "date-time" },
    "remediated_at":       { "type": ["string", "null"], "format": "date-time" },
    "owner":               { "type": "string", "description": "Who is responsible for fixing it (SCI dev team, Howie/FortiGate, Pressable, etc.)." },
    "deadline":            { "type": ["string", "null"], "format": "date" },
    "source":              { "type": "string", "enum": ["nuclei", "zap", "semgrep", "gitleaks", "trivy", "osv-scanner", "trufflehog", "testssl", "sslyze", "ffuf", "subzy", "dnstwist", "theharvester", "nmap", "nikto", "wpscan", "feroxbuster", "auth_bypass_probe", "manual_named", "sprocket_external", "wellgate_external", "commandsentry_asm", "other"] },
    "history":             { "type": "array", "items": { "$ref": "finding_history.schema.json" } },
    "evidence_ids":        { "type": "array", "items": { "type": "string" }, "description": "References to evidence_artifacts records." },
    "tags":                { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
